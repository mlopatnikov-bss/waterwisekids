  <script>
  // ── Search & Category Filter ──
  (function() {
    var searchInput = document.getElementById('articleSearch');
    var clearBtn = document.getElementById('searchClear');
    var grid = document.getElementById('articlesGrid');
    var cards = Array.from(grid.querySelectorAll('.article-card'));
    var filtersWrap = document.getElementById('categoryFilters');
    var resultsCount = document.getElementById('resultsCount');
    var activeCat = 'all';

    // Build category buttons from actual card data
    var cats = {};
    cards.forEach(function(c) {
      var tag = c.querySelector('.article-card-category');
      if (tag) { var t = tag.textContent.trim(); cats[t] = (cats[t] || 0) + 1; }
    });
    var sorted = Object.keys(cats).sort();
    sorted.forEach(function(name) {
      var btn = document.createElement('button');
      btn.className = 'cat-btn';
      btn.setAttribute('data-cat', name);
      btn.textContent = name;
      filtersWrap.appendChild(btn);
    });

    function filterCards() {
      var q = searchInput.value.toLowerCase().trim();
      clearBtn.style.display = q ? 'flex' : 'none';
      var shown = 0;
      cards.forEach(function(c) {
        var title = (c.querySelector('.article-card-title') || {}).textContent || '';
        var excerpt = (c.querySelector('.article-card-excerpt') || {}).textContent || '';
        var cat = (c.querySelector('.article-card-category') || {}).textContent || '';
        var matchSearch = !q || title.toLowerCase().indexOf(q) !== -1 || excerpt.toLowerCase().indexOf(q) !== -1 || cat.toLowerCase().indexOf(q) !== -1;
        var matchCat = activeCat === 'all' || cat.trim() === activeCat;
        if (matchSearch && matchCat) { c.style.display = ''; shown++; } else { c.style.display = 'none'; }
      });
      if (q || activeCat !== 'all') {
        resultsCount.textContent = shown + ' guide' + (shown !== 1 ? 's' : '') + ' found';
        resultsCount.style.display = 'block';
      } else {
        resultsCount.style.display = 'none';
      }
      // Show / hide no-results message
      var noMsg = document.getElementById('noResults');
      if (shown === 0) {
        if (!noMsg) {
          noMsg = document.createElement('div');
          noMsg.id = 'noResults';
          noMsg.className = 'no-results';
          noMsg.innerHTML = '<p><strong>No guides found.</strong></p><p>Try a different search term or clear your filters.</p>';
          grid.parentNode.insertBefore(noMsg, grid.nextSibling);
        }
        noMsg.style.display = 'block';
      } else if (noMsg) { noMsg.style.display = 'none'; }
    }

    searchInput.addEventListener('input', filterCards);
    clearBtn.addEventListener('click', function() { searchInput.value = ''; filterCards(); searchInput.focus(); });

    filtersWrap.addEventListener('click', function(e) {
      if (e.target.classList.contains('cat-btn')) {
        filtersWrap.querySelectorAll('.cat-btn').forEach(function(b) { b.classList.remove('active'); });
        e.target.classList.add('active');
        activeCat = e.target.getAttribute('data-cat');
        filterCards();
      }
    });
  })();
  </script>
