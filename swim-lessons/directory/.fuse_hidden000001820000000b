  <script>
    const STATE_CODE = "HI";

    let currentRating = 0;
    let currentSchoolId = null;

    // Initialize page
    function init() {
      renderStateSchools();
      setupStarRating();
      setupMobileMenu();
    }

    function renderStateSchools() {
      applySearch();
    }

    function applySearch() {
      const schoolName = document.getElementById('schoolSearch').value.toLowerCase();
      const city = document.getElementById('citySearch').value.toLowerCase();

      const schools = SWIM_SCHOOLS_DATA[STATE_CODE] || [];
      const filtered = schools.filter(school => {
        if (schoolName && !school.name.toLowerCase().includes(schoolName)) return false;
        if (city && !school.city.toLowerCase().includes(city)) return false;
        return true;
      }).map(s => ({ ...s, id: `${s.name}-${s.state}` }));

      const container = document.getElementById('schoolsList');
      if (filtered.length === 0) {
        container.innerHTML = '<div class="no-results"><h3>No schools found</h3><p>Try adjusting your search criteria.</p></div>';
        return;
      }

      container.innerHTML = filtered.map(school => renderSchoolCard(school)).join('');
    }

    function renderSchoolCard(school) {
      const programLabels = {
        'infant': 'Infants',
        'toddler': 'Toddlers',
        'preschool': 'Preschool',
        'school-age': 'School-age',
        'adult': 'Adults'
      };

      // Show user-generated reviews from localStorage only
      const schoolKey = school.name.replace(/[^a-zA-Z0-9]/g, '_');
      const storedReviews = JSON.parse(localStorage.getItem('reviews_' + schoolKey) || '[]');
      let ratingHTML = '';
      if (storedReviews.length > 0) {
        const avgRating = storedReviews.reduce((sum, r) => sum + r.rating, 0) / storedReviews.length;
        const userStars = '★'.repeat(Math.round(avgRating)) + '☆'.repeat(5 - Math.round(avgRating));
        ratingHTML = \`<div class="school-rating"><span class="star">\${userStars}</span><span>\${avgRating.toFixed(1)} (\${storedReviews.length} review\${storedReviews.length !== 1 ? 's' : ''})</span></div>\`;
      }

      return `
        <div class="school-card">
          <div class="school-header">
            <div>
              <h3 class="school-name">${school.name}</h3>
              <span class="school-chain">${school.chain}</span>
            </div>
            ${ratingHTML}
          </div>

          <div class="school-info">
            <div><strong>Location:</strong> ${school.address}, ${school.city}, ${school.state} ${school.zip}</div>
            <div><strong>Type:</strong> ${school.indoor ? 'Indoor' : 'Outdoor'}${school.yearRound ? ' • Year-round' : ''}</div>
          </div>

          <div class="school-programs">
            ${school.programs.map(p => `<span class="program-badge">${programLabels[p]}</span>`).join('')}
          </div>

          <div class="school-contact">
            <a href="tel:${school.phone.replace(/\D/g, '')}">${school.phone}</a>
            <a href="${school.website}" target="_blank">Visit Website</a>
          </div>

          <div class="school-actions">
            <button class="review-btn" onclick="openReviewModal('${school.id}', '${school.name.replace(/'/g, "\\'")}')">Leave a Review</button>
          </div>
        </div>
      `;
    }

    function openReviewModal(schoolId, schoolName) {
      currentSchoolId = schoolId;
      document.getElementById('reviewModal').classList.add('active');
      document.querySelector('.review-form h3').textContent = `Review: ${schoolName}`;
      currentRating = 0;
      document.getElementById('reviewText').value = '';
      updateStarDisplay();
    }

    function closeReviewModal() {
      document.getElementById('reviewModal').classList.remove('active');
      currentRating = 0;
      currentSchoolId = null;
    }

    function setupStarRating() {
      document.querySelectorAll('#starRating button').forEach(btn => {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          currentRating = parseInt(this.getAttribute('data-rating'));
          updateStarDisplay();
        });
      });
    }

    function updateStarDisplay() {
      document.querySelectorAll('#starRating button').forEach((btn, idx) => {
        btn.classList.toggle('active', idx + 1 <= currentRating);
      });
    }

    function submitReview(e) {
      e.preventDefault();

      if (currentRating === 0) {
        alert('Please select a rating');
        return;
      }

      const text = document.getElementById('reviewText').value.trim();
      if (!text) {
        alert('Please write a review');
        return;
      }

      // Store in localStorage
      const reviews = JSON.parse(localStorage.getItem('swimSchoolReviews') || '{}');
      if (!reviews[currentSchoolId]) {
        reviews[currentSchoolId] = [];
      }

      reviews[currentSchoolId].push({
        rating: currentRating,
        text: text,
        date: new Date().toISOString()
      });

      localStorage.setItem('swimSchoolReviews', JSON.stringify(reviews));
      alert('Thank you for your review!');
      closeReviewModal();
    }

    function setupMobileMenu() {
      const hamburger = document.querySelector('.hamburger');
      const nav = document.querySelector('nav');

      hamburger.addEventListener('click', function() {
        nav.classList.toggle('mobile-open');
        this.setAttribute('aria-expanded', nav.classList.contains('mobile-open'));
      });
    }

    // Initialize on load
    document.addEventListener('DOMContentLoaded', init);
  </script>
  <script src="/assets/js/main.js"></script>
</body>
</html>
