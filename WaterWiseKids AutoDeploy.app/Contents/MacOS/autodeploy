#!/bin/bash
# WaterWiseKids AutoDeploy — App Launcher
# Opens Terminal and runs the visible deploy loop.

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

# Find the deploy script — look relative to this .app first
APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
if [[ -f "$APP_DIR/.deploy/waterwisekids-deploy.sh" ]]; then
    DEPLOY_SCRIPT="$APP_DIR/.deploy/waterwisekids-deploy.sh"
else
    for DIR in "$HOME/Documents/Claude/Projects/WATERWISEKIDS.COM" \
               "$HOME/Documents/Claude/Projects/waterwisekids.com"; do
        if [[ -f "$DIR/.deploy/waterwisekids-deploy.sh" ]]; then
            DEPLOY_SCRIPT="$DIR/.deploy/waterwisekids-deploy.sh"
            break
        fi
    done
fi

if [[ -z "$DEPLOY_SCRIPT" || ! -f "$DEPLOY_SCRIPT" ]]; then
    osascript -e 'display alert "WaterWiseKids AutoDeploy" message "Could not find .deploy/waterwisekids-deploy.sh in the repo folder." as critical'
    exit 1
fi

chmod +x "$DEPLOY_SCRIPT" 2>/dev/null

# Open Terminal and run the deploy script
osascript -e "
tell application \"Terminal\"
    activate
    do script \"bash '$DEPLOY_SCRIPT'\"
end tell
"
